{
  "name": "skeleton-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview --host",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "clean:test": "pkill -f 'node.*vitest' || true",
    "clean:e2e": "pkill -f 'playwright test' || true",
    "pretest": "npm run clean:test",
    "test": "vitest",
    "test:run": "vitest run",
    "posttest": "npm run clean:test",
    "posttest:run": "npm run clean:test",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "posttest:coverage": "npm run clean:test",
    "pretest:e2e": "npm run clean:e2e",
    "test:e2e": "playwright test",
    "posttest:e2e": "npm run clean:e2e",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint . && npm run check",
    "push": "gh-pages -t -d build",
    "deploy": "npm run build && npm run push"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.4",
    "@iconify/svelte": "^4.2.0",
    "@playwright/test": "^1.56.1",
    "@skeletonlabs/skeleton": "^4.15.2",
    "@skeletonlabs/skeleton-svelte": "^4.15.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "jsdom": "^27.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "cookie": "^1.0.2"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  }
}
